      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Backend Auth Apple → Apple External (verify) -->
    <mxCell id="84" value="verify JWT" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#b85450;fontColor=#b85450;fontSize=10;dashed=1;" edge="1" source="37" target="51" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Backend Payments → YooKassa -->
    <mxCell id="85" value="API + webhook" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;fontColor=#82b366;fontSize=10;" edge="1" source="45" target="53" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Backend AI → Claude -->
    <mxCell id="86" value="API calls" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;fontColor=#82b366;fontSize=10;" edge="1" source="43" target="54" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Flutter Tariffs → Backend Payments (via WebView) -->
    <mxCell id="87" value="WebView confirmation_url" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d6b656;fontColor=#d6b656;fontSize=10;" edge="1" source="17" target="53" parent="1">
      <mxGeometry relative="1" as="geometry"/>
